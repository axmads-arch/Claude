generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  price       Float
  image       String?
  category    String
  available   Boolean     @default(true)
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model Order {
  id           Int         @id @default(autoincrement())
  customerName String
  phone        String
  address      String?
  total        Float
  status       String      @default("yangi")
  createdAt    DateTime    @default(now())
  items        OrderItem[]
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int
  price     Float
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
